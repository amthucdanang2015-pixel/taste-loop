{
  "name": "tasteloop-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:backend": "node scripts/run-with-backend.mjs dev",
    "build": "next build",
    "start": "next start",
    "start:backend": "node scripts/run-with-backend.mjs start",
    "typecheck": "tsc --noEmit --incremental false --pretty false",
    "typecheck:backend": "tsc -p amplify/tsconfig.json --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test tests/*.test.mjs",
    "test:media": "node --test tests/shipped-assets.test.mjs",
    "test:links": "node scripts/check-links.mjs",
    "verify:cdn": "node scripts/verify-asset-cdn.mjs",
    "verify:leads": "node scripts/verify-lead-e2e.mjs",
    "verify:backend": "npm run verify:cdn && node scripts/verify-lead-infrastructure.mjs",
    "production:configure": "node scripts/configure-vercel-production.mjs",
    "production:deploy": "vercel --prod --yes",
    "backend:deploy": "npm run check && node scripts/deploy-backend.mjs",
    "check": "npm run typecheck && npm run typecheck:backend && npm run lint && npm test"
  },
  "engines": {
    "node": ">=20.9 <25"
  },
  "overrides": {
    "postcss": "$postcss",
    "sharp": "0.35.3",
    "gray-matter": {
      "js-yaml": "3.15.0"
    }
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1093.0",
    "@aws-sdk/lib-dynamodb": "^3.1093.0",
    "@tailwindcss/typography": "^0.5.20",
    "framer-motion": "^11.3.19",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.417.0",
    "mp4-muxer": "^5.2.2",
    "next": "15.5.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@aws-amplify/backend": "1.23.0",
    "@aws-amplify/backend-cli": "1.8.3",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20.14.12",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "aws-cdk-lib": "2.261.0",
    "constructs": "10.7.0",
    "eslint": "9.39.5",
    "eslint-config-next": "15.5.21",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  }
}
